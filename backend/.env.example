APP_NAME=SmartHire AI
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=["http://localhost:5173"]
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=1234
DATABASE_NAME=smarthire_ai
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# Security Settings
JWT_SECRET_KEY=dev_secret_key_change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Argon2 Hashing Cost Parameters
PASSWORD_HASH_MEMORY_COST=65536
PASSWORD_HASH_TIME_COST=3
PASSWORD_HASH_PARALLELISM=4
PASSWORD_HASH_HASH_LEN=32
PASSWORD_HASH_SALT_LEN=16